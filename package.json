{
  "name": "uservoice-user-search",
  "version": "1.1.3",
  "description": "Reliable multi-strategy user search (by email or name) for the UserVoice API",
  "keywords": [
    "uservoice",
    "search",
    "user",
    "api"
  ],
  "author": "Byrne Reese <byrne.reese@ringcentral.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ringcentral/uservoice-user-search.git"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/uservoice-user-search/issues"
  },
  "homepage": "https://github.com/ringcentral/uservoice-user-search#readme",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.3.0",
    "rollup": "^4.60.4",
    "vitest": "^1.6.0"
  }
}
